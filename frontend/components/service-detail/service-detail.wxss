/* components/service-detail/service-detail.wxss */
.service-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
}
.modal-content {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 20rpx;
  height: 60%; /* 屏幕 3/5 */
  display: flex;
  flex-direction: column;
}
.close-icon {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
}
.service-detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}
.service-detail-item {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}