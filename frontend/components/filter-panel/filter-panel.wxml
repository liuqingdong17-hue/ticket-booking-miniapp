<!--components/filter-panel/filter-panel.wxml-->
<view class="filter-panel" wx:if="{{showFilter}}" catch:touchmove="{{true}}">
  <view class="filter-content">
    <!-- 价格 -->
    <view class="filter-item" bind:tap="togglePricePicker">
      <text class="filter-label">价格</text>
      <text class="filter-value">{{selectedPriceLabel}}</text>
    </view>
    <view class="picker-wrapper" wx:if="{{pricePickerShow}}">
      <scroll-view scroll-y="true" class="picker-scroller">
        <view class="picker-item" wx:for="{{priceOptions}}" wx:key="value" bind:tap="selectPrice" data-value="{{item.value}}">
          {{item.label}}
        </view>
      </scroll-view>
    </view>

    <!-- 时间 -->
    <view class="filter-item">
      <text class="filter-label">时间</text>
      <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange" class="filter-value">
        <text>{{selectedDate || '请选择'}}</text>
      </picker>
    </view>

    <!-- 城市 (点击打开省份选择，只显示选中的城市) -->
    <view class="filter-item" bind:tap="toggleCityPicker">
      <text class="filter-label">城市</text>
      <text class="filter-value">{{selectedCity || '请选择'}}</text>
    </view>

    <!-- 省份 Picker (选省份后隐藏，只用于逻辑) -->
    <view class="picker-wrapper" wx:if="{{provincePickerShow}}">
      <scroll-view scroll-y="true" class="picker-scroller">
        <view class="picker-item" wx:for="{{provinces}}" wx:key="name" bind:tap="selectProvince" data-value="{{item.name}}" data-code="{{item.code}}">
          {{item.name}}
        </view>
      </scroll-view>
    </view>

    <!-- 城市 Picker (选省份后显示该省城市) -->
    <view class="picker-wrapper" wx:if="{{cityPickerShow && currentCities.length > 0}}">
      <scroll-view scroll-y="true" class="picker-scroller">
        <view class="picker-item" wx:for="{{currentCities}}" wx:key="name" bind:tap="selectCity" data-value="{{item}}">
          {{item}}
        </view>
      </scroll-view>
    </view>

    <view class="locate-btn" bind:tap="onLocate">定位当前城市</view>

    <!-- 底部操作按钮 -->
    <view class="filter-actions">
      <view class="reset-btn" bind:tap="onReset">重置</view>
      <view class="cancel-btn" bind:tap="onClose">取消</view>
      <view class="confirm-btn" bind:tap="onConfirm">确认</view>
    </view>
  </view>
</view>