/* pages/ticket-buy/ticket-buy.wxss */
page {
  background-color: #f5f6f8;
}

.container {
  padding-bottom: 180rpx;
  min-height: 100vh;
}

/* --- 1. 顶部红色背景 --- */
.header-bg {
  margin-top: -200rpx;
  width: 90%;
  background: linear-gradient(to right, #ff4e6e, #ff2d55);
  padding: 40rpx 40rpx 80rpx; /* 底部留白给卡片上浮 */
  color: #fff;
}

.header-content {
  margin-top: 10rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 16rpx;
  /* 限制行数 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.sub-title {
  font-size: 24rpx;
  opacity: 0.9;
}

/* --- 主内容区域 (卡片上浮) --- */
.main-content {
  height: 1070rpx;
  width: 100%;
  padding: 0 12rpx;
  margin-top: -400rpx; /* 向上移动，盖住头部背景 */
  position: relative;
  z-index: 10;
}

/* --- 2. 票档区域 --- */
.section-box {
  width: 90%;
  height: 850rpx;
  margin-top: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  /* margin-bottom: 10rpx; */
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.tickets-wrapper {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between; /* 两端对齐 */
}

.ticket-item {
  width: 48%; /* 两个一行 */
  height: 110rpx;
  box-sizing: border-box;
  background: #fff;
  border: 2rpx solid #e6e6e6; /* 默认灰色边框 */
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  transition: all 0.2s;
}

/* 选中状态：粉框+粉字+浅粉背景 */
.ticket-item.active {
  border-color: #ff2d55;
  background-color: #fff0f3;
  color: #ff2d55;
}

/* 缺货状态：灰色背景+文字变淡 */
.ticket-item.sold-out {
  background-color: #f7f7f7;
  border-color: #eee;
  color: #ccc;
}

.ticket-info {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* 选中时文字变粉 */
.ticket-item.active .ticket-info {
  color: #ff2d55;
}

.ticket-item.sold-out .ticket-info {
  color: #ccc;
}

/* 缺货的小标签 */
.stock-tag {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  font-size: 20rpx;
  background: #f0f0f0;
  color: #999;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

/* --- 3. 数量选择区域 --- */
.count-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.count-left {
  display: flex;
  flex-direction: column;
}

.count-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.count-limit {
  font-size: 22rpx;
  color: #999;
}

.count-control {
  display: flex;
  align-items: center;
}

.c-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%; /* 圆形按钮 */
  background: #f5f5f5;
  color: #333;
  font-size: 36rpx;
  line-height: 56rpx; /* 垂直居中 */
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
  font-weight: 400;
}

.c-btn::after { border: none; }

.c-btn[disabled] {
  color: #ccc;
  background: #f9f9f9;
}

.c-btn.plus {
  background: #ff2d55;
  color: #fff;
}
.c-btn.plus[disabled] {
    background: #f9f9f9;
    color: #ccc;
}

.c-num {
  margin: 0 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  min-width: 40rpx;
  text-align: center;
}

/* --- 4. 底部结算栏 --- */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom); /* 适配全面屏底部黑条 */
}

.price-info {
  display: flex;
  flex-direction: column;
}

.total-wrapper {
  color: #ff2d55;
  display: flex;
  align-items: baseline;
}

.symbol {
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 4rpx;
}

.final-price {
  font-size: 44rpx;
  font-weight: 700;
}

.price-detail {
  font-size: 22rpx;
  color: #999;
  display: flex;
  align-items: center;
  margin-top: 4rpx;
}

.arrow {
  font-size: 18rpx;
  margin-left: 6rpx;
  transform: scale(0.8);
}

.confirm-btn {
  margin: 0;
  padding: 0;
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, #ff4e6e, #ff2d55);
  border-radius: 40rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.confirm-btn[disabled] {
  background: #ddd;
  color: #fff;
}