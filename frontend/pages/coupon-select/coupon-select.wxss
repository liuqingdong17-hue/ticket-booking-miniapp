.container {
  background: #f8f9fb;
  min-height: 100vh;
  padding-bottom: 80rpx;
  position: relative;
}

.coupon-list {
  padding: 10rpx 20rpx;
  margin-top: -190rpx;
}

.coupon-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  width: 700rpx;
  height: 230rpx;
}

.coupon-card.active {
  border: 2rpx solid #ff4d6d;
}

.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #ff7875, #ff4d6d);
  color: #fff;
  text-align: center;
  padding: 20rpx 0;
}

.coupon-value {
  font-size: 40rpx;
  font-weight: bold;
}

.coupon-type {
  font-size: 24rpx;
  opacity: 0.9;
}

.coupon-right {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.coupon-condition {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.coupon-date {
  font-size: 24rpx;
  color: #bbb;
}

.check-icon {
  position: absolute;
  top: 10rpx;
  right: 20rpx;
  font-size: 36rpx;
  color: #ff4d6d;
}

.empty-section {
  text-align: center;
  padding-top: 200rpx;
  color: #999;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.confirm-btn {
  position: fixed;
  right: 30rpx;
  bottom: 40rpx;
  background: #ff4d6d;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 12rpx rgba(255,77,79,0.3);
}
.confirm-btn:disabled {
  background: #ccc;
}
