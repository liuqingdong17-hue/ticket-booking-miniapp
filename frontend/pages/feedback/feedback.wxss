/* pages/feedback/feedback.wxss */
.page {
  padding: 30rpx;
  background: #f5f6fa;
  min-height: 100vh;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 30rpx;
  margin-bottom: 10rpx;
}

.picker-box {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.arrow {
  color: #999;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
}

.img-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  background: #e5e5e5;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
  color: #999;
}

.input {
  width: 100%;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
}

.submit-btn {
  margin-top: 50rpx;
  background: #ff2c7d;
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
}

.img-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 26rpx;
  z-index: 10;
}
