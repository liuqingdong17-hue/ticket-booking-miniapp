/* pages/artistDetail/artistDetail.wxss */
.artist-page {
  background: #fff;
  min-height: 100vh;
}

.artist-cover {
  width: 100%;
  height: 400rpx;
}

.artist-info {
  padding: 20rpx;
}

.artist-name {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: bold;
}

.verified {
  width: 32rpx;
  height: 32rpx;
  margin-left: 10rpx;
}

.artist-stats {
  margin: 10rpx 0;
  color: #666;
  font-size: 26rpx;
}

.artist-desc {
  font-size: 28rpx;
  margin-bottom: 20rpx;
  color: #333;
}

.follow-btn {
  background: linear-gradient(90deg, #ff3d77, #ff5f5f);
  color: #fff;
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
}

.section {
  margin-top: 30rpx;
  padding: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.performance-card {
  display: flex;
  margin-bottom: 20rpx;
}

.performance-card .cover {
  width: 160rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.performance-card .info {
  flex: 1;
}

.performance-card .title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.performance-card .time,
.performance-card .venue {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.buy-btn {
  background: #ff3d77;
  color: #fff;
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}
