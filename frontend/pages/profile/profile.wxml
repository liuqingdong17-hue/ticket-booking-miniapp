<!--pages/profile/profile.wxml-->
<view class="profile-page">
  <!-- 顶部用户信息 -->
  <view class="profile-header">
    <view class="user-info">
      <image class="avatar" src="{{user.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-text">
        <text class="nickname" bindtap="onLoginTap">{{ user.username || '登录/注册' }}</text>
      </view>
    </view>
    <button class="settings-btn" bindtap="onSettings">设置</button>
  </view>

  <!-- 数据统计 -->
  <view class="stats">
    <view class="stat-item" bindtap="goToFavorites">
      <text class="count">{{ userStats.want_count || 0 }}</text>
      <text class="label">想看的演出</text>
    </view>
    <view class="stat-item" bindtap="goToFollow">
      <text class="count">{{ userStats.follow_count || 0 }}</text>
      <text class="label">关注</text>
    </view>
    <view class="stat-item" bindtap="goToCoupons">
      <text class="count">{{ userStats.coupon_count || 0 }}</text>
      <text class="label">优惠券</text>
    </view>
  </view>

  <!-- 我的服务 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">我的服务</text>
    </view>
    <view class="service-grid">
      <view class="service-item" bindtap="goToOrders">
        <image src="/images/order.png" class="icon"></image>
        <text>我的订单</text>
      </view>
      <view class="service-item" bindtap="goToTickets">
        <image src="/images/ticket.png" class="icon"></image>
        <text>我的票夹</text>
      </view>
      <view class="service-item" bindtap="goToViewers">
        <image src="/images/viewer.png" class="icon"></image>
        <text>观演人</text>
      </view>
      <view class="service-item" bindtap="goToFeedback">
        <image src="/images/feedback.png" class="icon"></image>
        <text>意见反馈</text>
      </view>
    </view>
  </view>

  <!-- 其他功能 -->
<view class="card">
  <view class="card-header">
    <text class="card-title">更多功能</text>
  </view>
  <view class="service-grid">
    <view class="service-item" bindtap="goToPolicy">
      <image src="/images/policy.png" class="icon"></image>
      <text>协议规则</text>
    </view>
    <view class="service-item" bindtap="goToLicense">
      <image src="/images/license.png" class="icon"></image>
      <text>证照信息</text>
    </view>
    <view class="service-item" bindtap="goToService">
      <image src="/images/service.png" class="icon"></image>
      <text>在线客服</text>
    </view>
  </view>
</view>


  <!-- 底部信息 -->
  <view class="footer">
    <text>版本号 v2025.11.10</text>
    <text>客服电话：1010-3721</text>
  </view>
</view>
