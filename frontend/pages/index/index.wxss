/**index.wxss**/
/* 搜索框样式 */
.search-container {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin: 20rpx;
  background-color: #f5f5f5;
  border-radius: 48rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 20rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  border: none;
}

/* 分类样式 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 20rpx;
  margin: 0 20rpx;
}

.category-item {
  width: 30%;
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}

.category-label {
  font-size: 26rpx;
  color: #333;
}

/* 轮播图样式 */
.banner-wrapper {
  width: 100%;
  height: 200rpx;
  margin-bottom: 100rpx;
}

.banner-img {
  width: 100%;
  height: 200rpx;
  border-radius: 10rpx;
}
/* 推荐 */
/* 顶部标题和筛选按钮 */
.recommend-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 24rpx 0;  
  width: 100%;  
  font-size: 36rpx;
  font-weight: bold;
  background-color: #ffffff;
  border-bottom: 2rpx solid #f0f0f0;
}

.title {
  margin-right: auto;  
  padding-left: 32rpx;  
}

.filter-btn {
  font-size: 28rpx;
  padding: 8rpx 20rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 32rpx;
  line-height: 1;
  margin-right: 20rpx;  
  margin-left: 20rpx;  
}
/* 筛选面板 */
.filter-panel {
  padding: 20rpx 32rpx;
  background-color: #fafafa;
  border-bottom: 2rpx solid #eee;
}

.filter-group {
  margin-bottom: 20rpx;
}

.filter-group text {
  font-weight: 600;
  margin-right: 20rpx;
}
