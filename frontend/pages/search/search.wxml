<view class="search-page">
  <!-- 搜索框 -->
  <view class="search-header">
    <input 
      class="search-input" 
      value="{{keyword}}" 
      placeholder="搜索演出、艺人、场馆..."
      bindinput="onSearchInput" 
      bindconfirm="onSearch"   
    />
    <button class="search-btn" bindtap="onSearchBtn">搜索</button>
  </view>

  <!-- 演出和艺人结果展示 -->
  <scroll-view scroll-y style="height: 100vh;" bindscrolltolower="onScrollToLower">
    <!-- 演出结果 -->
    <block wx:for="{{internalPerformances}}" wx:key="id" wx:for-item="item">
      <view class="performance-card {{item.isExpired ? 'expired' : ''}}" bindtap="onPerformanceTap" data-id="{{item.id}}">
        <image src="{{item.cover_url}}" class="cover-image" />
        <!-- 已下架角标 -->
        <view wx:if="{{item.isExpired}}" class="expired-tag">已下架</view>

        <view class="performance-info">
          <view class="performance-title">{{item.name}}</view>
          <view class="performance-time">{{item.start_time}}</view>
          <view class="performance-venue">{{item.venue_name}}</view>
          <view class="performance-price">¥{{item.min_price}}</view>
        </view>
      </view>
    </block>

    <!-- 艺人结果 -->
    <block wx:for="{{artists}}" wx:key="id" wx:for-item="artist">
      <view class="artist-result-item" bindtap="onArtistTap" data-id="{{artist.id}}">
        <image src="{{artist.avatar}}" class="cover-image" />
        <view class="result-info">
          <text class="artist-name">{{artist.name}}</text>
          <text class="artist-followers">{{artist.fans_count}} 粉丝</text>
        </view>
      </view>
    </block>

    <!-- 无数据 -->
    <view wx:if="{{!internalPerformances.length && !artists.length}}" class="empty">暂无数据</view>

    <!-- 没有更多数据 -->
    <view wx:if="{{!hasMore && internalPerformances.length}}" class="end-tip">没有更多了~</view>
  </scroll-view>
</view>