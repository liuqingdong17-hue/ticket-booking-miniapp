/* pages/review/review.wxss */
.page {
  padding: 30rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.stars {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.star {
  width: 50rpx;
  height: 50rpx;
}

.textarea {
  width: 100%;
  height: 250rpx;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 90rpx;
  background: #e64340;
  color: #fff;
  font-size: 32rpx;
  border-radius: 16rpx;
  font-weight: bold;
}
