<!-- ✅ 艺人卡片：一对多 -->
<block wx:if="{{artists.length}}">
  <block wx:for="{{artists}}" wx:key="id">
    <view class="artist-card" bindtap="goArtistDetail" data-id="{{item.id}}">
      <view class="artist-left">
        <image class="artist-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
      </view>

      <view class="artist-middle">
        <view class="artist-name">{{item.name}}</view>
        <view class="artist-meta">{{item.fans || 0}} 粉丝 | {{item.shows || 0}} 场在售演出</view>
      </view>

      <!-- 点关注不要触发整张卡片跳转 -->
      <view class="artist-right" catchtap="toggleFollow" data-id="{{item.id}}" data-index="{{index}}">
        <view class="follow-btn {{item.isFollowing ? 'following' : ''}}">
          {{item.isFollowing ? '已关注' : '+ 关注'}}
        </view>
      </view>
    </view>
  </block>
</block>
<!-- 演出介绍 -->
<view class="performance-intro">
  <view class="section-header">
    <text class="section-title">演出介绍</text>
  </view>
  <view class="section-content">
    <rich-text nodes="{{performance.description}}"></rich-text>
  </view>
</view>

<!-- 用户评价模块 -->
<view class="review-section">

<view class="section-header">
  <text class="section-title">用户评价</text>
</view>

<!-- 无评论 -->
<view wx:if="{{reviews.length === 0}}" class="no-review">
  暂无评价
</view>

<!-- 有评论 -->
<block wx:for="{{reviews}}" wx:key="id">
  <view class="review-item">

    <!-- 头像 + 用户名 + 星星 -->
    <view class="review-header">
      <image class="avatar" src="/images/default-avatar.png"></image>
      <view class="user-info">
        <text class="username">{{item.username}}</text>

        <!-- 星星评分（rating 是 1-5） -->
        <!-- 星星评分 -->
        <view class="stars">
          <block wx:for="{{item.stars}}" wx:key="index">
            <image
              class="star"
              src="{{item ? '/images/star_on.png' : '/images/star_off.png'}}"
            />
          </block>
          
        </view>
      </view>
    </view>

    <!-- 评论内容 -->
    <view class="content">{{item.content}}</view>

    <!-- 时间 -->
    <view class="time">{{item.created_at}}</view>

  </view>
</block>

</view>

<!-- 底部固定栏 -->
<view class="bottom-bar">
  <!-- 分享 -->
 <button class="share-btn" open-type="share">
  <image class="icon" src="/images/share.png"></image>
  <text>分享</text>
</button>

  <!-- 添加想看 -->
  <view class="favorite-btn" bindtap="onToggleFavorite">
  <image class="favorite-icon" 
         src="{{isFavorite ? '/images/star-filled.png' : '/images/star.png'}}" />
  <text class="favorite-text">{{isFavorite ? '已想看' : '添加想看'}}</text>
</view>

  <!-- 立即购票 / 已下架 -->
<view class="buy-btn {{!performance.isAvailable ? 'disabled' : ''}}" 
      bindtap="{{performance.isAvailable ? 'onBuyNow' : ''}}">
  {{performance.isAvailable ? '立即购票' : '已下架'}}
</view>

</view>

  <!-- 座位图弹窗 -->
  <view wx:if="{{showSeatMapModal}}" class="seat-map-modal">
    <view class="modal-content">
      <image src="{{performance.seat_map_url}}" class="seat-map-image" mode="aspectFit" />
      <button class="close-btn" bindtap="closeSeatMapModal">关闭</button>
    </view>
  </view>

  <!-- 服务详情弹窗 -->
  <service-detail id="service-detail" wx:if="{{showServiceDetailsModal}}"/>

  <view wx:if="{{loading}}" class="loading">加载中...</view>
</view>