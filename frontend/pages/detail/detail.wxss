.page {
  padding: 20rpx;
  background: #f5f5f5;
}

.header {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.poster {
  width: 240rpx;
  height: 320rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.detail-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.time-block {
  display: flex;
  flex-direction: column;
  margin-bottom: 15rpx;
}

.start-time {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 5rpx;
}

.duration-text {
  font-size: 26rpx;
  color: #666;
}

.divider {
  height: 2rpx;
  background: #e5e5e5;
  margin: 15rpx 0;
}

.venue-block {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.venue-info {
  display: flex;
  flex-direction: column;
}

.venue-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 5rpx;
}

.venue-address {
  font-size: 26rpx;
  color: #666;
}

.seat-map-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
}

.seat-icon {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 5rpx;
}

.seat-text {
  font-size: 22rpx;
  color: #333;
  text-align: center;
}

.service-section {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  overflow-x: auto;
  margin-bottom: 10rpx;
}

.service-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.service-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
}

.service-text {
  font-size: 28rpx;
  color: #666;
}

.service-details-container {
  display: flex;
  align-items: center;
}

.arrow-text {
  font-size: 32rpx;
  color: #1890ff;
}

.seat-map-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  width: 80%;
  max-height: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.seat-map-image {
  width: 100%;
  max-height: 500rpx;
}

.close-btn {
  margin-top: 20rpx;
  padding: 10rpx 30rpx;
  background: #ccc;
  border-radius: 10rpx;
  border: none;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  color: #666;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 艺人卡片部分 */
.artist-card {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin: 24rpx 0rpx 0;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.06);
  align-items: center;
}

.artist-left {
  margin-right: 20rpx;
}

.artist-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f3f3f3;
}

.artist-middle {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.artist-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.artist-meta {
  font-size: 24rpx;
  color: #888;
}

.artist-right .follow-btn {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  border: 1rpx solid #ff2442;
  color: #ff2442;
  background: #fff;
}

.artist-right .follow-btn.following {
  border-color: #ddd;
  color: #666;
  background: #f5f5f5;
}

/* 演出介绍部分 */
.performance-intro {
  margin: 24rpx 0rpx 0;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  border-left: 8rpx solid #ff4d4f;  /* 左侧红色强调条 */
  padding-left: 16rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.section-content {
  font-size: 28rpx;
  color:#555;
  line-height: 1.6;
}
/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  display: flex;
  background: #fff;
  border-top: 1px solid #eee;
  height: 100rpx;
  z-index: 999;
}

.share-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  background: #fff;
  border: none;
}

.favorite-btn {
  width: 20rpx;
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to right, #FF9800, #FFB74D);
  color: #fff;
  font-size: 28rpx;
}
.favorite-icon{
  width: 50rpx;
  height: 50rpx;
}

.buy-btn {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to right, #FF4081, #FF80AB);
  color: #fff;
  font-size: 28rpx;
  border-top-left-radius: 50rpx;
  border-bottom-left-radius: 50rpx;
}

.buy-btn.disabled {
  background-color: #ccc;
  color: #666;
  pointer-events: none; /* 禁止点击 */
}


.icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}
/* 评分 */
.score-box {
  width: auto;
  margin: 5rpx;
  padding: 20rpx 30rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.score-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6600;
}

.score-stars {
  margin: 10rpx 0;
  display: flex;
  flex-direction: row;
}

.star {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.score-count {
  font-size: 24rpx;
  color: #888;
}

.score-none {
  font-size: 28rpx;
  color: #aaa;
  text-align: center;
  padding: 20rpx 0;
}
/* 评论*/
.review-section {
  padding: 20rpx 15rpx;
}

.review-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 5rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.review-header {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.review-header .avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 28rpx;
  font-weight: bold;
}

.stars {
  display: flex;
  margin-top: 6rpx;
}

.star {
  width: 28rpx;
  height: 28rpx;
  margin-right: 4rpx;
}

.content {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 40rpx;
}

.time {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.no-review {
  padding: 40rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #aaa;
}


