/* pages/viewer-select/viewer-select.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}


.list-section {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  width: 700rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 20rpx;
}

.viewer-list {
  padding: 0 20rpx 20rpx;
}

.viewer-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 5rpx 2rpx;  /* 进一步增加 padding，高度更宽敞 */
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;  /* 保持间距 */
  min-height: 140rpx;  /* 增加最小高度，防扁平 */
}

.viewer-card:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.viewer-left {
  width: 50rpx;  /* 圆点更大 */
  height: 50rpx;
  margin-right: 24rpx;  /* 增加间距 */
}

.select-dot {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  background-color: #fff;
}

.select-dot.active {
  border-color: #ff6b6b;
  background-color: #ff6b6b;
}

.viewer-info {
  display: flex;
  flex-direction: column;  /* 列布局，姓名上 ID 下 */
  align-items: flex-start;  /* 左对齐 */
  flex: 1;
  gap: 12rpx;  /* 增加间距 */
}

.viewer-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.viewer-idcard {
  font-size: 26rpx;
  color: #999;
  width: 100%;  /* 全宽，防溢出 */
}

.delete-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-left: 20rpx;  /* 增加间距 */
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}

.empty-section {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #999;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.add-btn {
  background: linear-gradient(135deg, #ff6b6b, #ff4d6f);
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 12rpx; 
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  margin: 0 20rpx;
  width: calc(100% - 40rpx);
}