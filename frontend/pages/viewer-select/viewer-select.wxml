<!--pages/viewer-select/viewer-select.wxml-->
<view class="container">

  <!-- 已添加观演人列表 (全宽卡片，增加高度) -->
  <view class="list-section" wx:if="{{viewerList.length > 0}}">
    <view class="section-title">已添加观演人</view>
    <view class="viewer-list">
      <block wx:for="{{viewerList}}" wx:key="id">
        <view class="viewer-card" bindtap="onSelectViewer" data-viewer="{{item}}">
          <view class="viewer-left">
            <view class="select-dot {{selectedViewerId === item.id ? 'active' : ''}}"></view>
          </view>
          <view class="viewer-info">
            <text class="viewer-name">{{item.name}}</text>
            <text class="viewer-idcard">{{item.masked_id_card}}</text>
          </view>
          <image class="delete-icon" src="/images/delete.png" data-id="{{item.id}}" catchtap="onDeleteViewer" />  <!-- 改 bindtap → catchtap -->
        </view>
      </block>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-section" wx:if="{{viewerList.length === 0}}">
    <view class="empty-icon">👥</view>
    <text class="empty-title">暂无观演人</text>
    <text class="empty-text">添加观演人以便购票</text>
  </view>

  <!-- 添加按钮 -->
  <button class="add-btn" bindtap="onAddViewer">添加观演人</button>
</view>