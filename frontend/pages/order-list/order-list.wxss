/* pages/order-list/order-list.wxss */
.page {
  background: #f8f8f8;
  min-height: 100vh;
  padding: 20rpx;
}

.header {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.order-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.cover {
  width: 180rpx;
  height: 240rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.venue {
  font-size: 26rpx;
  color: #999;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 10rpx;
}

.time {
  font-size: 28rpx;
  color: #666;
  margin-top: 12rpx;
}

.bottom {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
}

.price {
  color: #ff4d6f;
  font-weight: bold;
}

.empty {
  text-align: center;
  color: #aaa;
  margin-top: 200rpx;
}

.footer {
  text-align: center;
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #ccc;
}
