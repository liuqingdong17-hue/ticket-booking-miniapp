<view class="page">

<view class="header">我的订单</view>

<!-- 订单列表 -->
<block wx:for="{{orders}}" wx:key="order_id">
  <view class="order-card" bindtap="goDetail" data-id="{{item.order_id}}">
    
    <image class="cover" src="{{item.cover_url}}"></image>

    <view class="content">
      <text class="venue">{{item.venue_name}}</text>
      <text class="title">{{item.performance_name}}</text>
      <text class="time">{{item.schedule_time_fmt}}</text>

      <view class="bottom">
        <text class="count">共{{item.ticket_count}}张</text>
        <text class="price">实付 ¥{{item.pay_price}}</text>
      </view>
    </view>

  </view>
</block>

<!-- 空状态 -->
<view wx:if="{{orders.length === 0}}" class="empty">
  <text class="empty-text">暂无订单</text>
</view>

<view class="footer">—— 我是有底线的 ——</view>

</view>
