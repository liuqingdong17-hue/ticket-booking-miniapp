/* pages/admin-chat/admin-chat.wxss */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.chat-window {
  flex: 1;
  padding: 20rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
}

.admin-row {
  flex-direction: row;
}

.user-row {
  flex-direction: row-reverse;
}

.bubble {
  max-width: 65%;
  padding: 20rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
}

.admin-bubble {
  background: #fff;
  color: #333;
  margin-left: 20rpx;
}

.user-bubble {
  background: #ff4d6d;
  color: #fff;
  margin-right: 20rpx;
}

.bottom-bar {
  display: flex;
  padding: 10rpx;
  background: #fff;
  border-top: 1px solid #eee;
}

.input {
  flex: 1;
  padding: 20rpx;
  background: #f2f2f2;
  border-radius: 10rpx;
}

.send-btn {
  margin-left: 20rpx;
  background: #ff4d6d;
  color: #fff;
  padding: 0 30rpx;
  border-radius: 10rpx;
}
