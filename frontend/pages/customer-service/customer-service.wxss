.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f7fb;
}


/* 聊天窗口 */
.chat-window {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

/* 行排列 */
.msg-row {
  display: flex;
  margin-bottom: 22rpx;
  align-items: flex-start;
}

/* AI 左侧 */
.ai-row {
  flex-direction: row;
}

/* 用户右侧 */
.user-row {
  flex-direction: row-reverse;
}

/* 头像 */
.avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin: 0 12rpx;
}

/* 气泡基础 */
.bubble {
  padding: 22rpx 28rpx;
  border-radius: 20rpx;
  max-width: 65%;
  font-size: 26rpx;
  line-height: 38rpx;
}

/* AI 气泡 */
.ai-bubble {
  background: #ffffff;
  border: 1rpx solid #eee;
}

/* 用户消息气泡 */
.user-bubble {
  background: #ff4d6d;
  color: #fff;
}

/* 底部输入栏 */
.bottom-bar {
  display: flex;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  background: #f5f5f5;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.send-btn {
  margin-left: 16rpx;
  background: #ff4d6d;
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
}

/* 转人工 */
.switch-human {
  text-align: center;
  padding: 22rpx;
  font-size: 26rpx;
  color: #888;
}
