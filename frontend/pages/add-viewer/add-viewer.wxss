/* pages/add-viewer/add-viewer.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  width: 680rpx;
}

.input {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #eee;
}

.add-btn {
  background: linear-gradient(135deg, #ff6b6b, #ee5a52);  /* 粉色渐变 */
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 20rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.add-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}